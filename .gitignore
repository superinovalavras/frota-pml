# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# credentials / service accounts — NUNCA commitar
/credentials/
*service-account*.json
*-service-account*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Fotos originais grandes — só a versão otimizada em /public/veiculos vai pro git
/Foto dos carros/

# Claude Code: configurações locais do usuário (não compartilhar)
.claude/settings.local.json

# scratch local (geração de pptx, scripts de diagnóstico do banco)
/.pptx-build/

# Credenciais NUNCA entram no repositório (ele é público).
# Códigos de backup, senhas de app, chaves e afins moram FORA daqui —
# em gerenciador de senhas, ou em Documentos/FROTA-PML - Credenciais.
*ackup*ode*
*.key
*.pem
*credenciais*
*credentials*
*secret*
*senha*
