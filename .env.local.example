# =====================================================================
# FROTA PML — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# .env.local NÃO vai para o Git (está no .gitignore).
# =====================================================================

# Supabase — painel do projeto > Settings > API Keys
# URL pública do projeto:
NEXT_PUBLIC_SUPABASE_URL=https://rjdfzpvqevdswumdlgnr.supabase.co

# "Publishable key" (sb_publishable_...) — substitui a antiga "anon".
# Pode aparecer no navegador; é protegida pela RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "Secret key" (sb_secret_...) — substitui a antiga "service_role".
# SEGREDO. Só no servidor (rotas de admin, seed, jobs). Nunca commitar,
# nunca prefixar com NEXT_PUBLIC_. Fica na seção "Secret keys" da página.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — provedor de envio de email (https://resend.com).
# Necessário para o sistema enviar notificações (manutenção, cancelamento etc.).
# Sem isso, as mensagens ficam enfileiradas em `email_outbox` mas não saem.
RESEND_API_KEY=

# Remetente padrão. Formato: "Nome <email@dominio>".
# O domínio precisa estar verificado no Resend. Para testes use
# "onboarding@resend.dev" (Resend só permite enviar para o email da conta).
EMAIL_REMETENTE="FROTA PML <onboarding@resend.dev>"

# Segredo usado pelos cron jobs do Vercel para autorizar /api/email/dispatch
# e similares. Gere um valor aleatório longo e coloque também em
# Vercel > Project > Settings > Environment Variables.
CRON_SECRET=
